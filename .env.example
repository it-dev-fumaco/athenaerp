APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# For Docker: set APP_ENV=production and APP_DEBUG=false for production-like performance (enables config/route/view cache).
# Set XDEBUG_ENABLED=0 in .env and rebuild app image to disable Xdebug for faster requests.
APP_URL=http://localhost
# XDEBUG_ENABLED=0

# Disable Debugbar for faster XHR (e.g. view_deliveries, count_brochures). When unset, package may enable it if APP_DEBUG=true.
# DEBUGBAR_ENABLED=false

# --- Local performance (match live speed) ---
# Set in .env when you need faster local: APP_ENV=production APP_DEBUG=false DEBUGBAR_ENABLED=false XDEBUG_ENABLED=0
# Then: php artisan config:cache && php artisan route:cache && php artisan view:cache
# Rebuild app image if you change XDEBUG_ENABLED: docker compose build --no-cache app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# MES Database (mysql_mes connection)
DB_HOST_1=127.0.0.1
DB_PORT_1=3306
DB_DATABASE_1=
DB_USERNAME_1=
DB_PASSWORD_1=

BROADCAST_CONNECTION=log
# Use "file" when Redis is not available (e.g. single app container without Redis). Use "redis" with full docker-compose stack.
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
# Use "file" when Redis is not available. Use "redis" when running with docker-compose (Redis service).
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# For Docker Compose, app service sets REDIS_HOST=redis. For local/single-container, use file cache/session or run Redis.
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
